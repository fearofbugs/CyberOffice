# Copy this file to .env on the VM.

DOCKER_MONGODB_URI=mongodb://mongodb:27017/skyoffice
PORT=2567

# Optional local-only debug ports on the VM.
FRONTEND_HTTP_PORT=127.0.0.1:8080
BACKEND_HTTP_PORT=127.0.0.1:2567

# Required for production. Create a Cloudflare Tunnel token in the dashboard and
# store the full token here. Do not commit the real token.
CLOUDFLARE_TUNNEL_TOKEN=

# Public backend websocket URL. This should match the backend hostname in your
# Cloudflare Tunnel public hostnames.
VITE_SERVER_URL=wss://office.guix.tech
