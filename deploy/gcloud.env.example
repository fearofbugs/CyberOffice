# Copy this file to .env on the VM.
#
# The DNS A records for SITE_ADDRESS and BACKEND_SITE_ADDRESS must point to
# the external IP address of the Google Compute Engine VM before Caddy can
# issue HTTPS certificates.

DOCKER_MONGODB_URI=mongodb://mongodb:27017/skyoffice
PORT=2567

# Public frontend domain.
SITE_ADDRESS=meet.guix.tech

# Public backend/websocket domain.
BACKEND_SITE_ADDRESS=office.guix.tech

# The VM must allow inbound TCP 80 and 443.
HTTP_PORT=80
HTTPS_PORT=443

# Browser websocket URL baked into the client image at build time.
VITE_SERVER_URL=wss://office.guix.tech

# Fast production Docker build skips the separate TypeScript check and runs
# Vite bundling only. Set to build if you want Docker to run tsc first.
CLIENT_BUILD_COMMAND=build:fast
