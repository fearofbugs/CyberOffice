DOCKER_MONGODB_URI=mongodb://mongodb:27017/skyoffice
PORT=2567

# Production on a standalone VM where this stack owns ports 80 and 443.
# Caddy will issue HTTPS certificates for these domains.
# Example: SITE_ADDRESS=meet.guix.tech
# Example: BACKEND_SITE_ADDRESS=office.guix.tech
SITE_ADDRESS=:80
BACKEND_SITE_ADDRESS=office.localhost

HTTP_PORT=80
HTTPS_PORT=443

# Optional override. Leave empty to use the same host as the loaded page.
# Use this when frontend and backend use different domains.
# Example: VITE_SERVER_URL=wss://office.guix.tech
VITE_SERVER_URL=
