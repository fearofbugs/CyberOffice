DOCKER_MONGODB_URI=mongodb://mongodb:27017/skyoffice
PORT=2567

# Production behind an existing reverse proxy/Caddy.
# Use http:// so this inner Caddy does not try to issue public certificates.
# Example: SITE_ADDRESS=http://meet.guix.tech
# Example: BACKEND_SITE_ADDRESS=http://office.guix.tech
SITE_ADDRESS=:80
BACKEND_SITE_ADDRESS=office.localhost

# External Docker network used by the public reverse proxy stack.
DOCKER_NETWORK=serenity_default

# This Compose file does not publish 80/443 directly. Your existing public
# Caddy should reverse proxy meet.guix.tech and office.guix.tech to:
#   skyoffice-client:80

# Optional override. Leave empty to use the same host as the loaded page.
# Use this when frontend and backend use different domains.
# Example: VITE_SERVER_URL=wss://office.guix.tech
VITE_SERVER_URL=
